TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user ids allowed to use the bot in groups
ALLOWED_TELEGRAM_USER_IDS=123,456

# Text trigger mode:
# - find_only: handle text only when it starts with /find (recommended for groups)
# - all_text: handle any text message from allowed users
TEXT_TRIGGER_MODE=find_only

# Speech-to-text (Whisper)
# OpenAI-compatible API key for /audio/transcriptions.
# You can use OpenAI, Groq, or any compatible provider.
STT_API_KEY=
# Optional legacy name (supported too)
OPENAI_API_KEY=

# Optional: override transcription endpoint (OpenAI-compatible).
# If empty, uses https://api.openai.com/v1/audio/transcriptions
STT_ENDPOINT=
# Model name for your provider (examples):
# - OpenAI: whisper-1
# - Groq: whisper-large-v3-turbo
STT_MODEL=whisper-1

# OpenRouter (LLM for keywords)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Apify (TikTok keyword search)
APIFY_API_TOKEN=
# Recommended actor (has query/date_posted/sort_by inputs):
# https://apify.com/sociavault/tiktok-keyword-search-scraper
APIFY_ACTOR_ID=sociavault/tiktok-keyword-search-scraper
APIFY_REGION=US
APIFY_MAX_RESULTS=50
