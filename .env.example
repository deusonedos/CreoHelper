TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user ids allowed to use the bot in groups
ALLOWED_TELEGRAM_USER_IDS=123,456

# Speech-to-text (Whisper)
OPENAI_API_KEY=
# Optional: override transcription endpoint (OpenAI-compatible).
# If empty, uses https://api.openai.com/v1/audio/transcriptions
STT_ENDPOINT=
# Optional: whisper model name
STT_MODEL=whisper-1

# OpenRouter (LLM for keywords)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Apify (TikTok keyword search)
APIFY_API_TOKEN=
# Recommended actor (has query/date_posted/sort_by inputs):
# https://apify.com/sociavault/tiktok-keyword-search-scraper
APIFY_ACTOR_ID=sociavault/tiktok-keyword-search-scraper
APIFY_REGION=US
APIFY_MAX_RESULTS=50
