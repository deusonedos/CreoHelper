{
  "name": "tiktok-creatives-telegram-bot-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "MVP Telegram bot: voice/text -> keywords (OpenRouter) -> TikTok search (Apify) -> links",
  "main": "dist/bot.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/bot.ts",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build",
    "start": "node dist/bot.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "form-data": "^4.0.4",
    "grammy": "^1.37.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  }
}
